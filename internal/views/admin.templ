	<div class="page-header">
		<h1>{ org.Name }</h1>
	</div>
	<div class="card">
		<div class="card-header">Organization Details</div>
		<div class="card-body">
			<div class="meta-grid">
				<div class="meta-item">
					<div class="meta-label">ID</div>
					<div class="meta-value font-mono text-sm">{ org.ID.String() }</div>
				</div>
				<div class="meta-item">
					<div class="meta-label">Name</div>
					<div class="meta-value">{ org.Name }</div>
				</div>
				<div class="meta-item">
					<div class="meta-label">Sector</div>
					<div class="meta-value font-mono text-sm">{ org.SectorID.String() }</div>
				</div>
			</div>
		</div>
	</div>
}

