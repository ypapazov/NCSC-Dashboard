templ AdminUsers(users []*domain.User, total int) {
	<div class="page-header">
		<h1>User Management</h1>
	</div>
	<div id="user-list">
		if len(users) > 0 {
			<div class="card" style="overflow:hidden;">
				<table class="table">
					<thead>
						<tr>
							<th class="table-header">Name</th>
							<th class="table-header">Email</th>
							<th class="table-header">Primary Org</th>
							<th class="table-header">Actions</th>
						</tr>
					</thead>
					<tbody>
						for _, u := range users {
							<tr class="table-row">
								<td class="table-cell">{ u.DisplayName }</td>
								<td class="table-cell text-sm">{ u.Email }</td>
								<td class="table-cell text-sm font-mono">{ u.PrimaryOrgID.String() }</td>
								<td class="table-cell">
									<button class="btn btn-sm"
										hx-get={ "/api/v1/users/" + u.ID.String() } hx-target="#app" hx-swap="innerHTML"
										hx-push-url={ "/users/" + u.ID.String() }>
										View
									</button>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
			<p class="text-sm text-muted" style="margin-top:.5rem;">{ fmt.Sprintf("%d user(s) total", total) }</p>
		} else {
			<div class="card">
				<div class="card-body" style="text-align:center;padding:3rem;">
					<p class="text-muted">No users found.</p>
				</div>
			</div>
		}
	</div>
}

templ UserDetail(user *domain.User) {
	<div class="page-header">
		<h1>{ user.DisplayName }</h1>
		<span class="text-muted text-sm">{ user.Email }</span>
	</div>
	<div class="card">
		<div class="card-header">Profile</div>
		<div class="card-body">
			<div class="meta-grid">
				<div class="meta-item">
					<div class="meta-label">ID</div>
					<div class="meta-value text-sm font-mono">{ user.ID.String() }</div>
				</div>
				<div class="meta-item">
					<div class="meta-label">Display Name</div>
					<div class="meta-value">{ user.DisplayName }</div>
				</div>
				<div class="meta-item">
					<div class="meta-label">Email</div>
					<div class="meta-value">{ user.Email }</div>
				</div>
				<div class="meta-item">
					<div class="meta-label">Primary Organization</div>
					<div class="meta-value font-mono text-sm">{ user.PrimaryOrgID.String() }</div>
				</div>
			</div>
		</div>
	</div>
}

templ UserForm(user *domain.User) {
	<div class="page-header">
		if user != nil {
			<h1>Edit User</h1>
		} else {
			<h1>Create User</h1>
		}
	</div>
	<div class="card">
		<div class="card-body">
			<form hx-post="/api/v1/users" hx-target="#app" hx-swap="innerHTML">
				<div class="form-group">
					<label class="form-label">Display Name</label>
					if user != nil {
						<input type="text" name="display_name" class="form-input" required value={ user.DisplayName }/>
					} else {
						<input type="text" name="display_name" class="form-input" required value=""/>
					}
				</div>
				<div class="form-group">
					<label class="form-label">Email</label>
					if user != nil {
						<input type="email" name="email" class="form-input" required value={ user.Email }/>
					} else {
						<input type="email" name="email" class="form-input" required value=""/>
					}
				</div>
				<div class="form-actions">
					<button type="submit" class="btn btn-primary">Save</button>
					<a class="btn" hx-get="/api/v1/users" hx-target="#app" hx-swap="innerHTML" hx-push-url="/users">Cancel</a>
				</div>
			</form>
		</div>
	</div>
}

templ AdminRoles(data AdminRolesData) {
	<div class="page-header">
		<div>
			<a class="text-muted text-sm" hx-get="/api/v1/admin/users" hx-target="#app" hx-swap="innerHTML"
				hx-push-url="/admin/users">&larr; Back to Users</a>
			<h1 style="margin-top:.25rem;">Roles for { data.UserName }</h1>
		</div>
	</div>
	<div class="card">
		<div class="card-header">Assigned Roles</div>
		<div class="card-body">
			if len(data.Roles) > 0 {
				<table class="table">
					<thead>
						<tr>
							<th class="table-header">Role</th>
							<th class="table-header">Scope Type</th>
							<th class="table-header">Scope</th>
							<th class="table-header">Actions</th>
						</tr>
					</thead>
					<tbody>
						for _, role := range data.Roles {
							<tr class="table-row">
								<td class="table-cell"><span class="badge badge-severity-info">{ role.Role }</span></td>
								<td class="table-cell text-sm">{ role.ScopeType }</td>
								<td class="table-cell text-sm">{ role.ScopeName }</td>
								<td class="table-cell">
									<button class="btn btn-sm btn-danger"
										hx-delete={ fmt.Sprintf("/api/v1/admin/users/%s/roles/%s?scope_type=%s&scope_id=%s", data.UserID.String(), role.Role, role.ScopeType, role.ScopeID.String()) }
										hx-target="#app" hx-swap="innerHTML"
										hx-confirm={ "Revoke role " + role.Role + "?" }>
										Revoke
									</button>
								</td>
							</tr>
						}
					</tbody>
				</table>
			} else {
				<p class="text-muted text-sm">No roles assigned.</p>
			}
		</div>
	</div>
	<div class="card">
		<div class="card-header">Assign Role</div>
		<div class="card-body">
			<form hx-post={ "/api/v1/admin/users/" + data.UserID.String() + "/roles" }
				hx-target="#app" hx-swap="innerHTML">
				<div class="form-row">
					<div class="form-group">
						<label class="form-label" for="role">Role</label>
						<select id="role" name="role" class="form-select" required>
							<option value="">Select role&hellip;</option>
							<option value="PLATFORM_ROOT">Platform Root</option>
							<option value="SECTOR_ROOT">Sector Root</option>
							<option value="ORG_ROOT">Org Root</option>
							<option value="ORG_ADMIN">Org Admin</option>
							<option value="CONTENT_ADMIN">Content Admin</option>
							<option value="CONTRIBUTOR">Contributor</option>
							<option value="VIEWER">Viewer</option>
							<option value="LIAISON">Liaison</option>
						</select>
					</div>
					<div class="form-group">
						<label class="form-label" for="scope_type">Scope Type</label>
						<select id="scope_type" name="scope_type" class="form-select" required>
							<option value="">Select scope&hellip;</option>
							<option value="PLATFORM">Platform</option>
							<option value="SECTOR">Sector</option>
							<option value="ORG">Organization</option>
						</select>
					</div>
				</div>
				<div class="form-group">
					<label class="form-label" for="scope_id">Scope Target</label>
					<select id="scope_id" name="scope_id" class="form-select">
						<option value="">Platform-wide (no specific target)</option>
						for _, opt := range data.ScopeOptions {
							<option value={ opt.ID.String() }>{ opt.Name } ({ opt.Type })</option>
						}
					</select>
					<span class="form-hint">For PLATFORM scope, leave target empty. For SECTOR or ORG, select the target.</span>
				</div>
				<div class="form-actions">
					<button type="submit" class="btn btn-primary btn-sm">Assign Role</button>
				</div>
			</form>
		</div>
	</div>
}
