package views

import (
	"fmt"
	"fresnel/internal/domain"
)

templ AdminSectors(sectors []*domain.Sector) {
	<div class="page-header">
		<h1>Sector Management</h1>
	</div>
	<div id="sector-tree">
		if len(sectors) > 0 {
			<div class="card">
				<div class="card-body">
					<div class="tree">
						for _, s := range sectors {
							<div class="tree-node">
								<div class="tree-node-header">
									<span class="tree-node-name">{ s.Name }</span>
									<span class="tree-node-meta">
										<span class="text-xs text-dim">depth { fmt.Sprintf("%d", s.Depth) }</span>
										<span class="text-xs font-mono text-dim">{ s.AncestryPath }</span>
										<button class="btn btn-sm"
											hx-get={ "/api/v1/sectors/" + s.ID.String() } hx-target="#app" hx-swap="innerHTML"
											hx-push-url={ "/sectors/" + s.ID.String() }>
											View
										</button>
									</span>
								</div>
							</div>
						}
					</div>
				</div>
			</div>
		} else {
			<div class="card">
				<div class="card-body" style="text-align:center;padding:3rem;">
					<p class="text-muted">No sectors defined yet.</p>
				</div>
			</div>
		}
	</div>
}

templ SectorDetail(sector *domain.Sector) {
	<div class="page-header">
		<h1>{ sector.Name }</h1>
	</div>
	<div class="card">
		<div class="card-header">Sector Details</div>
		<div class="card-body">
			<div class="meta-grid">
				<div class="meta-item">
					<div class="meta-label">ID</div>
					<div class="meta-value font-mono text-sm">{ sector.ID.String() }</div>
				</div>
				<div class="meta-item">
					<div class="meta-label">Name</div>
					<div class="meta-value">{ sector.Name }</div>
				</div>
				<div class="meta-item">
					<div class="meta-label">Depth</div>
					<div class="meta-value">{ fmt.Sprintf("%d", sector.Depth) }</div>
				</div>
				<div class="meta-item">
					<div class="meta-label">Ancestry Path</div>
					<div class="meta-value font-mono text-sm">{ sector.AncestryPath }</div>
				</div>
			</div>
		</div>
	</div>
}

templ SectorForm(sector *domain.Sector) {
	<div class="page-header">
		if sector != nil {
			<h1>Edit Sector</h1>
		} else {
			<h1>Create Sector</h1>
		}
	</div>
	<div class="card">
		<div class="card-body">
			<form hx-post="/api/v1/sectors" hx-target="#app" hx-swap="innerHTML">
				<div class="form-group">
					<label class="form-label">Name</label>
					if sector != nil {
						<input type="text" name="name" class="form-input" required value={ sector.Name }/>
					} else {
						<input type="text" name="name" class="form-input" required value=""/>
					}
				</div>
				<div class="form-actions">
					<button type="submit" class="btn btn-primary">Save</button>
					<a class="btn" hx-get="/api/v1/sectors" hx-target="#app" hx-swap="innerHTML" hx-push-url="/sectors">Cancel</a>
				</div>
			</form>
		</div>
	</div>
}

templ AdminOrgs(orgs []*domain.Organization) {
	<div class="page-header">
		<h1>Organization Management</h1>
	</div>
	<div id="org-list">
		if len(orgs) > 0 {
			<div class="card" style="overflow:hidden;">
				<table class="table">
					<thead>
						<tr>
							<th class="table-header">Name</th>
							<th class="table-header">Sector</th>
							<th class="table-header">Created</th>
							<th class="table-header">Actions</th>
						</tr>
					</thead>
					<tbody>
						for _, o := range orgs {
							<tr class="table-row">
								<td class="table-cell">{ o.Name }</td>
								<td class="table-cell text-sm font-mono">{ o.SectorID.String() }</td>
								<td class="table-cell text-sm text-muted">{ FmtTime(o.CreatedAt) }</td>
								<td class="table-cell">
									<button class="btn btn-sm"
										hx-get={ "/api/v1/orgs/" + o.ID.String() } hx-target="#app" hx-swap="innerHTML"
										hx-push-url={ "/orgs/" + o.ID.String() }>
										View
									</button>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		} else {
			<div class="card">
				<div class="card-body" style="text-align:center;padding:3rem;">
					<p class="text-muted">No organizations found.</p>
				</div>
			</div>
		}
	</div>
}

