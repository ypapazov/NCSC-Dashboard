# Fresnel production environment — copy to .env and fill in real values.
# NEVER commit .env to version control.

# --- PostgreSQL ---
POSTGRES_PASSWORD=CHANGEME_strong_random_password

# --- Keycloak ---
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=CHANGEME_strong_random_password

# --- Fresnel ---
KEYCLOAK_ISSUER=http://keycloak:8080/realms/fresnel
KEYCLOAK_CLIENT_ID=fresnel-app
# Keycloak is proxied through nginx at /realms/ — same origin as the app.
KEYCLOAK_EXTERNAL_URL=https://fresnel.example.org/realms/fresnel
APP_PUBLIC_URL=https://fresnel.example.org

# --- ClamAV ---
CLAMAV_ADDRESS=clamav:3310

# --- Email (nudge/escalation) ---
# On AWS: set SES_REGION to use the SES API with instance-role credentials (no keys needed).
# On-prem/vSphere: leave SES_REGION empty and set SMTP_HOST instead.
# If both are set, SES takes priority.
SES_REGION=eu-west-2
SMTP_FROM=noreply@fresnel.example.org

# SMTP fallback (used when SES_REGION is empty):
#SMTP_HOST=relay.internal.example.org
#SMTP_PORT=587
#SMTP_USERNAME=
#SMTP_PASSWORD=

# --- Backups ---
FRESNEL_BACKUP_DIR=/data/backups
FRESNEL_ATTACHMENT_DIR=/data/attachments
FRESNEL_BACKUP_GPG_RECIPIENT=
FRESNEL_BACKUP_RETAIN_DAYS=30
