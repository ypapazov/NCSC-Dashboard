# VCS and CI
.git
.github

# Local / secrets (never ship in image context)
.env
.env.*
!.env.example
*.log

# Dev-only and large artifacts
bin/
.aikdb/
docs/
*.md

# Terraform state and local overrides (may contain secrets)
infra/aws/terraform.tfstate
infra/aws/terraform.tfstate.backup
infra/aws/*.tfvars
!infra/aws/terraform.tfvars.example

# TLS private keys (dev certs); public material may be copied if present
deploy/nginx/certs/*.key
